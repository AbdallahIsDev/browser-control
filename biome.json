{
	"$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"biome.json",
			"!dist",
			"!web/dist",
			"!dist-desktop",
			"!dist-desktop-2",
			"automation-packages/tradingview-ict-analysis/**/*.json",
			"package.json",
			"scripts/ci_package_smoke.cjs",
			"web/**",
			"desktop/**",
			"src/web/**",
			"tests/unit/web_app_server.test.ts",
			"tests/unit/web_frontend_format.test.ts",
			"tests/unit/desktop_security.test.ts"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
