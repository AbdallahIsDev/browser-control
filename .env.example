# browser-control environment example
# Copy values you need into a local .env file before running.

# Data directory
BROWSER_CONTROL_HOME=

# Broker / server
BROKER_PORT=7788
# Set BROKER_API_KEY before exposing broker beyond one trusted local process.
# Without an auth key, config mutation endpoints fail closed.
BROKER_API_KEY=
# Legacy fallback for broker auth. Prefer BROKER_API_KEY for new setups.
BROKER_SECRET=
# Optional task target allowlist for broker-submitted URLs/domains.
BROKER_ALLOWED_DOMAINS=
# Optional CORS allowlist. Empty means local wildcard read behavior; browser-origin requests still need auth when no broker key is configured.
BROKER_ALLOWED_ORIGINS=
BROKER_RATE_LIMIT_WINDOW_MS=60000
BROKER_RATE_LIMIT_MAX_REQUESTS=100

# Chrome / CDP
BROWSER_DEBUG_PORT=9222
# 127.0.0.1 is safest. 0.0.0.0 exposes unauthenticated CDP on reachable interfaces.
BROWSER_BIND_ADDRESS=127.0.0.1
BROWSER_CHROME_PATH=
BROWSER_DEBUG_URL=
BROWSER_MODE=managed
# Explicit opt-in only. Starts a private-interface WSL bridge to the unauthenticated CDP port.
BROWSER_ENABLE_WSL_CDP_BRIDGE=0

# Remote browser providers
BROWSERLESS_ENDPOINT=
BROWSERLESS_API_KEY=

# Stealth
ENABLE_STEALTH=false
STEALTH_LOCALE=
STEALTH_TIMEZONE_ID=
BROWSER_USER_AGENT=
STEALTH_FINGERPRINT_SEED=
STEALTH_WEBGL_VENDOR=
STEALTH_WEBGL_RENDERER=
STEALTH_PLATFORM=
STEALTH_HARDWARE_CONCURRENCY=
STEALTH_DEVICE_MEMORY=

# Proxy
PROXY_LIST=

# CAPTCHA
CAPTCHA_PROVIDER=
CAPTCHA_API_KEY=
CAPTCHA_TIMEOUT_MS=120000

# AI / OpenRouter / Stagehand
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
AI_AGENT_MODEL=
STAGEHAND_MODEL=google/gemini-2.5-flash-preview:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_AGENT_COST_PER_TOKEN=0.0001

# Daemon
RESUME_POLICY=abandon
MEMORY_ALERT_MB=1024
CHROME_TAB_LIMIT=20
DAEMON_VISIBLE=false

# Logging
LOG_LEVEL=info
LOG_FILE=false

# Policy
POLICY_PROFILE=balanced

# Terminal
TERMINAL_SHELL=
TERMINAL_COLS=80
TERMINAL_ROWS=24
TERMINAL_MAX_OUTPUT_BYTES=1048576
TERMINAL_MAX_SCROLLBACK_LINES=10000
TERMINAL_MAX_SERIALIZED_SESSIONS=50
TERMINAL_RESUME_POLICY=resume
TERMINAL_AUTO_RESUME=true
