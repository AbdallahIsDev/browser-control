{
  "name": "browser-control",
  "version": "1.0.0",
  "description": "AI-powered browser automation platform — Playwright, Stagehand, and CDP.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "bc": "./cli.js"
  },
  "files": [
    "dist/",
    "cli.js",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "node --require ts-node/register --require tsconfig-paths/register --test --test-concurrency=1",
    "compat:test": "node --require ts-node/register --require tsconfig-paths/register --test compatibility/package_import_smoke.test.ts compatibility/public_surface.test.ts",
    "compat:update": "node scripts/update_public_surface_snapshots.cjs",
    "broker:start": "ts-node broker_server.ts",
    "daemon": "ts-node daemon.ts",
    "daemon:dev": "ts-node daemon.ts --dev",
    "typecheck": "tsc --noEmit",
    "start": "ts-node main.ts",
    "cli": "ts-node cli.ts"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.6.1",
    "node-gyp": "^12.2.0",
    "node-pty": "^1.1.0",
    "playwright": "^1.54.2",
    "ws": "^8.20.0",
    "zod": "^3.25.76"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AbdallahIsDev/browser-control.git"
  },
  "homepage": "https://github.com/AbdallahIsDev/browser-control#readme",
  "bugs": {
    "url": "https://github.com/AbdallahIsDev/browser-control/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
